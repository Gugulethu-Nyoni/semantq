script:

let name = 'World!'; 


let counter = 0;


function incrementer () {
	
counter++;

}



function decrementer () {
	

	counter--;
}

let day = 'Monday';

let buttonStatus ='someValue';

end:


content:


Hello {name}

<div> 

<table class="table">
<thead>
<tr>
<th> Name </th>
<th> Surname </th>
<th> Email </th> 
</tr>
</thead>

<tbody>

<tr>
<td> Musa  </td>
