<button id={counter} @click={incrementer} > + </button> 
<button @click={decrementer}  > - </button> 

</td> 

</tr>

</tbody>
</table>


<div id="form-div">

<form method="post" action="process.php" class={day}>

<input id="27" type="text" value={counter} data-bind="name" />

</form> 

