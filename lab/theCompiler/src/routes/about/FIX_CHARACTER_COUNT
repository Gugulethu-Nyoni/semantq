script:
let total = 0;

const textInput = document.getElementById('text-input');
textInput.addEventListener('input', characterCounter);


function characterCounter(){
  
  const text = textInput.value;
  total = text.length;


}





end:


style:

end: 



content:

<div> 
Search Input: <input type="text" id="text-input" placeholder="Type text here" /> <br/> 

<h4> Total: {total} </h4>

</div>



