script:
  let counter = 0;
  let num = 1; 

  function increment() {
    counter += 1;
  }

  function doubler () {
   
   num = counter * 2;


  }


end:

<button @click={increment}>
  Button Clicked {counter} times
</button>

<br/> 
<p @click={doubler}> Counter: {counter} and Num: {num} </p>
<input type="text" value={counter} />