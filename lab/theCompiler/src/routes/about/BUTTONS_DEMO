script:

let counter = 0;

function incrementer () {
  
  ++counter;

}


function decrementer () {
  
  --counter;
}



end:


style:


end: 



content:

<div> 
<p> Count Value: {counter} </p> 

<button @click={incrementer} id={counter}> + </button> <br/> 
<button @click={decrementer}> - </button> <br/> 

Button Clicked: {counter} times! 


</div>




end:

