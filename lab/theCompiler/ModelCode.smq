<script>
	let count = 0;

	function handleClick() {
		count += 1;
	}
</script>

<h2> Hello World </h2> 

@if (a === b) 

<button @click={handleClick}>
	Clicked {count}
	{count === 1 ? 'time' : 'times'}
</button>

@endif



